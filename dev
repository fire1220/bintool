}

declare IsPostJenkins=false
declare IsNoCheckout=false
declare IsVPN=false
declare -a JenkinsParams=()
declare RulePrefix=""
OPTIND=1
while getopts ":r:-:jshv" opt;do
    case "$opt" in
        s)
            IsNoCheckout=true
            ;;
        h)
            helpInfo
            ;;
        j)
            IsPostJenkins=true
            ;;
        v)
            IsVPN=true
            ;;
        r)
            RulePrefix="$OPTARG"
            ;;
        -)
            argKeyLong=${OPTARG%%=*}
            if [[ "$OPTARG" =~ = ]];then
                case "$argKeyLong" in
                    "rule-prefix")
                        RulePrefix="${OPTARG#*=}"
                        ;;
                    *)
                        if [[ "$argKeyLong" =~ ^jenkins_ ]];then
                            JenkinsParams+=("--${OPTARG#jenkins_}")
                        fi
                        ;;
                esac
                continue
            else
                case "$argKeyLong" in
                    "help")
                        helpInfo
                        ;;
                    "jenkins")
                        IsPostJenkins=true
                        ;;
                    "self")
                        IsNoCheckout=true
                        ;;
                    *)
                        ;;
                esac
                continue
            fi
        ;;
    esac
done
shift $(($OPTIND-1))

declare DevelopmentBranch="$COMMAND_NAME"

declare -r COMMIT_INFO="$1"
if [[ "$COMMIT_INFO" == "" ]];then
    echo "input commit info"
    exit 1
fi

function getCurrentBranchName(){
    local branchList
    local grepList
    local currentBranchName
    branchList=$(git branch) || {
        return 11
    }
    grepList=$(echo "$branchList" | grep "*") || {
        echo "grep no find branch" >&2
        return 12
    }
    currentBranchName=$(echo "$grepList" | awk '{print $2}')
    if [[ "$currentBranchName" == "" ]] ;then
        echo "awk no find branch name" >&2
        return 13
    fi
    echo "$currentBranchName"
    return 0
}

function git_current_branch() {
  local ref
  ref=$(git symbolic-ref --quiet HEAD 2> /dev/null)
  local ret=$?
  if [[ $ret != 0 ]]; then
    [[ $ret == 128 ]] && {
        return 21 # no git repo.
    }
    ref=$(git rev-parse --short HEAD 2> /dev/null) || {
        return 22
    }
  fi
  echo ${ref#refs/heads/}
}

function getDevelopmentBranchByRulePrefix(){
    local devBranch="$DevelopmentBranch"
    if [[ "$RulePrefix" == "" ]];then
        echo "$devBranch"
        return 0
    fi
    for val in $(echo "$RulePrefix" |tr ',' '\n');do
        if [[ "$val" != *:* ]];then
            echo  >&2 "--rule-prefix=$val ж јејҸй”ҷиҜҜ, ж јејҸйңҖжҳҜпјҡ prefix1:targetBranch1,prefix2:targetBranch2"
            return 1
        fi
        local prefix="${val%%:*}"
        local targetBranch="${val#*:}"
        if [[ "$prefix" != "" ]] && [[ "$targetBranch" != "" ]];then
            if [[ "$(git_current_branch)" == "$prefix"* ]];then
                devBranch="$targetBranch"
                break
            fi
        fi
    done
    echo "$devBranch"
}

declare -r VPN_LIST=(
    "/opt/cisco/anyconnect/bin/vpn:ciscoAnyconnectVPN_func"
    # "openvpnLogin:openvpn_func"
)
declare -r VPN_STSTUS_ON="on"
declare -r VPN_STSTUS_OFF="off"
declare VpnCurrentStatus=false
declare VpnCurrentAppIsOpen=false

function ciscoAnyconnectVPN_func() {
    local vpnAppName="Cisco AnyConnect Secure Mobility Client"
    local vpnFuncPath="$1"
    local vpnStatus="$2"
    if ! $(command -v "$vpnFuncPath" > /dev/null 2>&1);then
        echo >&2 "е‘Ҫд»ӨжңӘжүҫеҲ°пјҡ$vpnFuncPath"
        return 1
    fi
    if [[ "$vpnStatus" != "$VPN_STSTUS_ON" ]] && [[ "$vpnStatus" != "$VPN_STSTUS_OFF" ]];then
        echo >&2 "зҠ¶жҖҒй”ҷиҜҜпјҡиҜ·иҫ“е…ҘVPNзҠ¶жҖҒпјҡon/off"
        return 2
    fi
    local errorCountNum=0
    local vpnAddress=""
    local bashName=$(basename "$SHELL")
    if [[ "$CISCO_ANYCONNECT_VPN_HOST" != "" ]];then
        vpnAddress="$CISCO_ANYCONNECT_VPN_HOST"
    elif [[ "$bashName" == "bash" ]];then
        if [[ -f ~/.bashrc ]];then
            vpnAddress=$(grep 'CISCO_ANYCONNECT_VPN_HOST' ~/.bashrc | tail -n1 | awk -F'[ =]+' '{print $NF}')
            CISCO_ANYCONNECT_VPN_HOST="$vpnAddress"
        fi
    elif [[ "$bashName" == "zsh" ]];then
        if [[ -f ~/.zshrc ]];then
            vpnAddress=$(grep 'CISCO_ANYCONNECT_VPN_HOST' ~/.zshrc | tail -n1 | awk -F'[ =]+' '{print $NF}')
            CISCO_ANYCONNECT_VPN_HOST="$vpnAddress"
        fi
    fi
    if [[ "$vpnAddress" == "" ]];then
        while read -p "иҜ·иҫ“е…ҘVPNиҝһжҺҘзҡ„жңҚеҠЎеҷЁең°еқҖ:" -r vpnServerAddress ;do
            if [[ "$vpnServerAddress" != "" ]];then
                vpnAddress="$vpnServerAddress"
                break
            fi
            ((errorCountNum++))
            if ((errorCountNum >= 3));then
                echo >&2 "иҫ“е…Ҙй”ҷиҜҜж¬Ўж•°иҝҮеӨҡпјҢйҖҖеҮә"
                return 1
            fi
        done
    fi
    local actionCmd="connect"
    if [[ "$vpnStatus" == "$VPN_STSTUS_OFF" ]];then
        actionCmd="disconnect"
    fi
    currentBranchNameTemp=$(git_current_branch) || {
        return 1
    }
    commandPrefix="\033[32m[$(date '+%F %T')] \033[36m$DIR_NAME\033[32m (\033[31;1m$currentBranchNameTemp\033[0;32m)\033[1m вһң \033[0m"

    if [[ "$vpnStatus" == "$VPN_STSTUS_ON" ]];then
        local vpnStatusMsg=$($vpnFuncPath stats|grep 'Connection State' |grep -v Management|awk -F'[: ]+' '{print $NF}')
        if [[ "$vpnStatusMsg" == "Connected" ]];then
            VpnCurrentStatus=true
            echo  -e "${commandPrefix}\033[33mVPN е·ІиҝһжҺҘпјҢж— йңҖйҮҚеӨҚиҝһжҺҘ \033[0m"
            return 0
        fi
        if [[ "$vpnStatusMsg" == "Disconnected" ]];then
            echo  -e "${commandPrefix}\033[33mVPN иҪҜд»¶е·Іжү“ејҖдҪҶжҳҜжңӘй“ҫжҺҘпјҢе°қиҜ•е…ій—ӯеӣҫеҪўе®ўжҲ·з«Ҝ \033[0m"
            pkill -f "$vpnAppName"
            if [[ "$?" == "0" ]];then
                VpnCurrentAppIsOpen=true
            fi
        fi
    elif ${VpnCurrentStatus} && [[ "$vpnStatus" == "$VPN_STSTUS_OFF" ]];then
        echo  -e "${commandPrefix}\033[33mVPN еҺҹжң¬е°ұжҳҜе·ІиҝһжҺҘзҠ¶жҖҒпјҢж— йңҖжү§иЎҢж–ӯејҖиҝһжҺҘж“ҚдҪң \033[0m"
        return 0
    fi

    echo  -e "${commandPrefix}\033[33m${vpnFuncPath} ${actionCmd} ${vpnAddress}\033[0m"
    $vpnFuncPath "$actionCmd" "$vpnAddress"

    if ${VpnCurrentAppIsOpen} && [[ "$vpnStatus" == "$VPN_STSTUS_OFF" ]];then
        echo  -e "${commandPrefix}\033[33mVPN е°қиҜ•жү“ејҖеӣҫеҪўе®ўжҲ·з«ҜиҪҜд»¶ \033[0m"
        open -a "$vpnAppName"
    fi

    if [[ "$CISCO_ANYCONNECT_VPN_HOST" == "" ]];then
        local vpnStatusMsg=$($vpnFuncPath stats|grep 'Connection State' |grep -v Management|awk -F'[: ]+' '{print $NF}')
        if [[ "$vpnStatusMsg" == "Connected" ]];then
            if [[ "$bashName" == "bash" ]];then
                echo "export CISCO_ANYCONNECT_VPN_HOST=$vpnAddress" >> ~/.bashrc
                . ~/.bashrc
            elif [[ "$bashName" == "zsh" ]];then
                echo "export CISCO_ANYCONNECT_VPN_HOST=$vpnAddress" >> ~/.zshrc
            fi
        fi
    fi
}

function openvpn_func() {
    echo ""
}


function useVPN() {
    if ! $IsVPN ;then
        return 0
    fi
    local vpnStatus="$1"
    if [[ "$vpnStatus" != "$VPN_STSTUS_ON" ]] && [[ "$vpnStatus" != "$VPN_STSTUS_OFF" ]];then
        echo >&2 "зҠ¶жҖҒй”ҷиҜҜпјҡиҜ·иҫ“е…ҘVPNзҠ¶жҖҒпјҡon/off"
        return 2
    fi
    local availableVpnList=()
    for v in ${VPN_LIST[@]};do
        cmdStr="${v%:*}"
        if command -v "$cmdStr" > /dev/null 2>&1;then
            availableVpnList+=("$cmdStr")
        fi
    done
    local vpnFuncInfo=""
    if [[ "${#availableVpnList[@]}" == "1" ]];then
        vpnFuncInfo="${VPN_LIST[0]}"
    else
        local k=0
        for val in ${availableVpnList[@]} ;do
            ((k++))
            printf " %s\t%s\n" "$k" "$val"
        done
        local errorCountNum=0
        while read -p "иҜ·йҖүжӢ©VPNиҝһжҺҘпјҲиҫ“е…ҘеәҸеҸ·[1-${#availableVpnList[@]}]пјү:" -r vpnIndex ;do
            if [[ "${vpnIndex}" =~ ^[1-9]+$ ]];then
                vpnFuncInfo="${VPN_LIST[$vpnIndex-1]}"
                if [[ "$vpnFuncInfo" != "" ]];then
                    break
                fi
            fi
            ((errorCountNum++))
            if ((errorCountNum >= 3));then
                echo >&2 "иҫ“е…Ҙй”ҷиҜҜж¬Ўж•°иҝҮеӨҡпјҢйҖҖеҮә"
                return 1
            fi
        done
    fi
    local vpnFuncName="${vpnFuncInfo#*:}"
    local vpnFuncPath="${vpnFuncInfo%:*}"
    $vpnFuncName "$vpnFuncPath" "$vpnStatus"
}

function main(){
    local currentBranchName
    currentBranchName=$(git_current_branch) || {
        local tempCode="$?"
        if [[ "$tempCode" == "21" ]];then
            echo "not a git repository"
        fi
        return $tempCode
    }

    DevelopmentBranch="$(getDevelopmentBranchByRulePrefix 2>&1)" || {
        echo "$DevelopmentBranch"
    }

    if [[ "$currentBranchName" == "$DevelopmentBranch" ]];then
        echo "current is target development branch"
        return 1
    fi
    if $IsRestrictMasterBranch ;then
        if [[ "$MasterBranch" == "$currentBranchName" ]];then
            while read -p "еҪ“еүҚжӯЈеңЁж“ҚдҪң${MasterBranch}еҲҶж”ҜпјҢжҳҜеҗҰз»§з»ӯж“ҚдҪңпјҡ(N/y):" -r row ;do
                if [[ "$row" == "N" || "$row" == "n" || "$row" == "" ]];then
                    echo "exit"
                    return 0
                fi
                if [[ "$row" == "Y" || "$row" == "y" ]];then
                    break;
                fi
            done
        fi
    fi
    local execList
    local gitLogOne="git --no-pager log --no-color -n 1"
    execList=(
        "git --no-pager diff"
        "git add -A"
        "git commit -m '$COMMIT_INFO'"
        "git pull"
        "git push"
        "git checkout $DevelopmentBranch"
        "git pull"
        "git merge $currentBranchName -m 'Merge branch $currentBranchName into $DevelopmentBranch'"
        "git push"
        "$gitLogOne"
        "git checkout $currentBranchName"
    );
    if $IsNoCheckout ;then
        execList=(
            "git --no-pager diff"
            "git add -A"
            "git commit -m '$COMMIT_INFO'"
            "git pull"
            "git push"
        );
    fi
    local implemented
    local commitId=""
    local currentBranchNameTemp
    for commandStr in "${execList[@]}" ;do
        if [[ "$implemented" == "$commandStr" ]];then
            continue
        fi
        implemented="$commandStr"
        dateTime=$(date '+%F %T')
        currentBranchNameTemp=$(git_current_branch) || {
            return 1
        }
        commandPrefix="\033[32m[$dateTime] \033[36m$DIR_NAME\033[32m (\033[31;1m$currentBranchNameTemp\033[0;32m)\033[1m вһң \033[0m"
        echo  -e "${commandPrefix}\033[33m${commandStr}\033[0m"

        if [[ "$commandStr" == "$gitLogOne" ]];then
            commitId=$(eval "$commandStr" | head -n1 | awk '{print $2}')
        fi

        eval "$commandStr" || {
            echo ""
            echo -e "Execution Failed"
            echo -e "   Solution:"
            echo -e "       вҖў p: Push Again    "
            echo -e "       вҖў s: Skip          "
            echo -e "       вҖў e: Exit          "
            str=$(echo -e  "\033[31;1mSelect Execution(p/s or e):\033[0m")
            while read -p "$str" -r row ;do
                if [[ "$row" == "e" || "$row" == "E" ]];then
                    return 1
                elif [[ "$row" == "s" || "$row" == "S" ]];then
                    break
                elif [[ "$row" == "p" || "$row" == "P" ]];then
                    local conflictExecList=(
                        "git add -A"
                        "git commit -m 'resolve the conflictпјҡ$COMMIT_INFO'"
                        "git pull"
                        "git push"
                    )
                    for val in "${conflictExecList[@]}" ;do
                        dateTime=$(date '+%F %T')
                        implemented="$val"
                        echo  -e "${commandPrefix}\033[33m${val}\033[0m"
                        eval "$val" || {
                            return 1
                        }
                    done
                    break
                else
                    continue
                fi
            done
        }
    done
    if $IsPostJenkins ;then
        if [[ "$commitId" != "" ]];then
            currentBranchNameTemp=$(git_current_branch) || {
                return 1
            }
            commandPrefix="\033[32m[$dateTime] \033[36m$DIR_NAME\033[32m (\033[31;1m$currentBranchNameTemp\033[0;32m)\033[1m вһң \033[0m"
            declare params=""
            for v in "${JenkinsParams[@]}"; do
                params="${params} $v"
            done
            local evalStr="jenkins \"$commitId\""
            if [[ "$params" != "" ]];then
                evalStr="jenkins${params} \"$commitId\""
            fi
            echo  -e "${commandPrefix}\033[33m${evalStr}\033[0m"
            eval "$evalStr"
        fi
    fi
}

useVPN "$VPN_STSTUS_ON"
main
useVPN "$VPN_STSTUS_OFF"
